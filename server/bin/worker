#!/usr/bin/env node

const { logger }                = require('../lib/logger');
const { BreakTransitionWorker,
        TechFallTrackerWorker,
        MatchUpdateWorker,
        RoundTimerWorker }      = require('../lib/workerQueue');



const workerToken = process.argv[2];
if (workerToken) {
    new TechFallTrackerWorker(workerToken).start();
    new MatchUpdateWorker(workerToken).start();
    new BreakTransitionWorker(workerToken).start();
    new RoundTimerWorker(workerToken).start();
} else {
    logger.error('Missing worker token. Unable to start worker');
}
