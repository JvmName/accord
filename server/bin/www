#!/usr/bin/env node
const { ApplicationServer } = require('../lib/server');
const { spawn }             = require('node:child_process');


const server = new ApplicationServer();

const workerArgs = ['run', 'worker', server.workerToken];
const workerEnv  = {
    ...process.env,
    PORT: server.port,
    PROC_NAME: 'WORKER'
};
const worker = spawn('npm', workerArgs, {env: workerEnv});
worker.stdout.on('data', data => console.log(data.toString().trim()));
worker.stderr.on('data', data => console.log(data.toString().trim()));


const handler = () => {
    server.close();
    worker.kill();
};
process.on('SIGINT',  handler);
process.on('SIGTERM', handler);
process.on('SIGUSR2', handler);


server.listen();
